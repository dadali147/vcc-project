<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.user.mapper.UserAccountMapper">

    <resultMap type="com.vcc.user.domain.UserAccount" id="UserAccountResult">
        <result property="id"              column="id"               />
        <result property="userId"          column="user_id"          />
        <result property="balance"         column="balance"          />
        <result property="frozenAmount"    column="frozen_amount"    />
        <result property="currency"        column="currency"         />
        <result property="totalRecharge"   column="total_recharge"   />
        <result property="totalWithdraw"   column="total_withdraw"   />
        <result property="status"          column="status"           />
        <result property="createTime"      column="created_at"       />
        <result property="updateTime"      column="updated_at"       />
    </resultMap>

    <sql id="selectUserAccountVo">
        select id, user_id, balance, frozen_amount, currency, total_recharge, total_withdraw,
               status, created_at, updated_at
        from vcc_user_account
    </sql>

    <select id="selectUserAccountById" parameterType="Long" resultMap="UserAccountResult">
        <include refid="selectUserAccountVo"/>
        where id = #{id}
    </select>

    <select id="selectUserAccountByUserId" resultMap="UserAccountResult">
        <include refid="selectUserAccountVo"/>
        where user_id = #{userId} and currency = #{currency}
    </select>

    <select id="selectUserAccountList" parameterType="com.vcc.user.domain.UserAccount" resultMap="UserAccountResult">
        <include refid="selectUserAccountVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="currency != null and currency != ''">AND currency = #{currency}</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertUserAccount" parameterType="com.vcc.user.domain.UserAccount" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_user_account (
            <if test="userId != null">user_id,</if>
            <if test="balance != null">balance,</if>
            <if test="frozenAmount != null">frozen_amount,</if>
            <if test="currency != null and currency != ''">currency,</if>
            <if test="totalRecharge != null">total_recharge,</if>
            <if test="totalWithdraw != null">total_withdraw,</if>
            <if test="status != null">status,</if>
            created_at
        ) values (
            <if test="userId != null">#{userId},</if>
            <if test="balance != null">#{balance},</if>
            <if test="frozenAmount != null">#{frozenAmount},</if>
            <if test="currency != null and currency != ''">#{currency},</if>
            <if test="totalRecharge != null">#{totalRecharge},</if>
            <if test="totalWithdraw != null">#{totalWithdraw},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        )
    </insert>

    <update id="updateUserAccount" parameterType="com.vcc.user.domain.UserAccount">
        update vcc_user_account
        <set>
            <if test="balance != null">balance = #{balance},</if>
            <if test="frozenAmount != null">frozen_amount = #{frozenAmount},</if>
            <if test="totalRecharge != null">total_recharge = #{totalRecharge},</if>
            <if test="totalWithdraw != null">total_withdraw = #{totalWithdraw},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="deductBalance">
        update vcc_user_account
        set balance = balance - #{amount}, updated_at = sysdate()
        where user_id = #{userId} and currency = #{currency} and balance >= #{amount}
    </update>

    <update id="addBalance">
        update vcc_user_account
        set balance = balance + #{amount},
            total_recharge = total_recharge + #{amount},
            updated_at = sysdate()
        where user_id = #{userId} and currency = #{currency}
    </update>

</mapper>
