<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.channel.mapper.VccChannelMapper">

    <resultMap id="VccChannelResult" type="com.vcc.channel.domain.VccChannel">
        <result property="id"           column="id"            />
        <result property="channelCode"  column="channel_code"  />
        <result property="channelName"  column="channel_name"  />
        <result property="status"       column="status"        />
        <result property="apiBaseUrl"   column="api_base_url"  />
        <result property="apiConfig"    column="api_config"    />
        <result property="remark"       column="remark"        />
        <result property="delFlag"      column="del_flag"      />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectVo">
        select id, channel_code, channel_name, status, api_base_url, api_config,
               remark, del_flag, created_at, updated_at
        from vcc_channel
        where del_flag = '0'
    </sql>

    <select id="selectById" parameterType="Long" resultMap="VccChannelResult">
        <include refid="selectVo"/>
        and id = #{id}
    </select>

    <select id="selectByChannelCode" parameterType="String" resultMap="VccChannelResult">
        <include refid="selectVo"/>
        and channel_code = #{channelCode}
    </select>

    <select id="selectList" parameterType="com.vcc.channel.domain.VccChannel" resultMap="VccChannelResult">
        <include refid="selectVo"/>
        <if test="channelCode != null and channelCode != ''">
            and channel_code = #{channelCode}
        </if>
        <if test="channelName != null and channelName != ''">
            and channel_name like concat('%', #{channelName}, '%')
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by id desc
    </select>

    <insert id="insert" parameterType="com.vcc.channel.domain.VccChannel" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_channel (channel_code, channel_name, status, api_base_url, api_config, remark)
        values (#{channelCode}, #{channelName}, #{status}, #{apiBaseUrl}, #{apiConfig}, #{remark})
    </insert>

    <update id="update" parameterType="com.vcc.channel.domain.VccChannel">
        update vcc_channel
        <set>
            <if test="channelName != null and channelName != ''">channel_name = #{channelName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="apiBaseUrl != null and apiBaseUrl != ''">api_base_url = #{apiBaseUrl},</if>
            <if test="apiConfig != null">api_config = #{apiConfig},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id} and del_flag = '0'
    </update>

    <update id="deleteById" parameterType="Long">
        update vcc_channel set del_flag = '1' where id = #{id}
    </update>

</mapper>
