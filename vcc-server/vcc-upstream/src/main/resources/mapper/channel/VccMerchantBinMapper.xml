<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.channel.mapper.VccMerchantBinMapper">

    <resultMap id="VccMerchantBinResult" type="com.vcc.channel.domain.VccMerchantBin">
        <result property="id"          column="id"           />
        <result property="merchantId"  column="merchant_id"  />
        <result property="binId"       column="bin_id"       />
        <result property="status"      column="status"       />
        <result property="assignedAt"  column="assigned_at"  />
        <result property="assignedBy"  column="assigned_by"  />
        <result property="remark"      column="remark"       />
        <result property="delFlag"     column="del_flag"     />
        <result property="createdAt"   column="created_at"   />
        <result property="updatedAt"   column="updated_at"   />
    </resultMap>

    <sql id="selectVo">
        select id, merchant_id, bin_id, status, assigned_at, assigned_by,
               remark, del_flag, created_at, updated_at
        from vcc_merchant_bin
        where del_flag = '0'
    </sql>

    <select id="selectById" parameterType="Long" resultMap="VccMerchantBinResult">
        <include refid="selectVo"/>
        and id = #{id}
    </select>

    <select id="selectByMerchantAndBin" resultMap="VccMerchantBinResult">
        <include refid="selectVo"/>
        and merchant_id = #{merchantId}
        and bin_id = #{binId}
    </select>

    <select id="selectByMerchantId" parameterType="Long" resultMap="VccMerchantBinResult">
        <include refid="selectVo"/>
        and merchant_id = #{merchantId}
        order by assigned_at desc
    </select>

    <select id="selectList" parameterType="com.vcc.channel.domain.VccMerchantBin" resultMap="VccMerchantBinResult">
        <include refid="selectVo"/>
        <if test="merchantId != null">
            and merchant_id = #{merchantId}
        </if>
        <if test="binId != null">
            and bin_id = #{binId}
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by assigned_at desc
    </select>

    <insert id="insert" parameterType="com.vcc.channel.domain.VccMerchantBin" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_merchant_bin (merchant_id, bin_id, status, assigned_by, remark)
        values (#{merchantId}, #{binId}, #{status}, #{assignedBy}, #{remark})
    </insert>

    <update id="update" parameterType="com.vcc.channel.domain.VccMerchantBin">
        update vcc_merchant_bin
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="assignedBy != null">assigned_by = #{assignedBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id} and del_flag = '0'
    </update>

    <update id="deleteById" parameterType="Long">
        update vcc_merchant_bin set del_flag = '1' where id = #{id}
    </update>

</mapper>
