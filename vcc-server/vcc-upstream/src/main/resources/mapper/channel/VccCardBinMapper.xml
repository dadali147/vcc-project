<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.channel.mapper.VccCardBinMapper">

    <resultMap id="VccCardBinResult" type="com.vcc.channel.domain.VccCardBin">
        <result property="id"                 column="id"                   />
        <result property="bin"                column="bin"                  />
        <result property="cardOrg"            column="card_org"             />
        <result property="cardType"           column="card_type"            />
        <result property="channelId"          column="channel_id"           />
        <result property="cardProductId"      column="card_product_id"      />
        <result property="defaultLimitAmount" column="default_limit_amount" />
        <result property="status"             column="status"               />
        <result property="remark"             column="remark"               />
        <result property="delFlag"            column="del_flag"             />
        <result property="createdAt"          column="created_at"           />
        <result property="updatedAt"          column="updated_at"           />
    </resultMap>

    <sql id="selectVo">
        select id, bin, card_org, card_type, channel_id, card_product_id,
               default_limit_amount, status, remark, del_flag, created_at, updated_at
        from vcc_card_bin
        where del_flag = '0'
    </sql>

    <select id="selectById" parameterType="Long" resultMap="VccCardBinResult">
        <include refid="selectVo"/>
        and id = #{id}
    </select>

    <select id="selectList" parameterType="com.vcc.channel.domain.VccCardBin" resultMap="VccCardBinResult">
        <include refid="selectVo"/>
        <if test="bin != null and bin != ''">
            and bin = #{bin}
        </if>
        <if test="cardOrg != null and cardOrg != ''">
            and card_org = #{cardOrg}
        </if>
        <if test="cardType != null and cardType != ''">
            and card_type = #{cardType}
        </if>
        <if test="channelId != null">
            and channel_id = #{channelId}
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by id desc
    </select>

    <select id="selectByChannelId" parameterType="Long" resultMap="VccCardBinResult">
        <include refid="selectVo"/>
        and channel_id = #{channelId}
        order by id asc
    </select>

    <insert id="insert" parameterType="com.vcc.channel.domain.VccCardBin" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_card_bin (bin, card_org, card_type, channel_id, card_product_id,
                                  default_limit_amount, status, remark)
        values (#{bin}, #{cardOrg}, #{cardType}, #{channelId}, #{cardProductId},
                #{defaultLimitAmount}, #{status}, #{remark})
    </insert>

    <update id="update" parameterType="com.vcc.channel.domain.VccCardBin">
        update vcc_card_bin
        <set>
            <if test="cardOrg != null and cardOrg != ''">card_org = #{cardOrg},</if>
            <if test="cardType != null and cardType != ''">card_type = #{cardType},</if>
            <if test="channelId != null">channel_id = #{channelId},</if>
            <if test="cardProductId != null">card_product_id = #{cardProductId},</if>
            <if test="defaultLimitAmount != null">default_limit_amount = #{defaultLimitAmount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id} and del_flag = '0'
    </update>

    <update id="deleteById" parameterType="Long">
        update vcc_card_bin set del_flag = '1' where id = #{id}
    </update>

</mapper>
