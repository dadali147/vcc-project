<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.card.mapper.CardMapper">

    <resultMap type="com.vcc.card.domain.Card" id="CardResult">
        <result property="id"               column="id"                 />
        <result property="holderId"          column="holder_id"          />
        <result property="userId"            column="user_id"            />
        <result property="cardNoMask"        column="card_no_mask"       />
        <result property="cardBinId"         column="card_bin_id"        />
        <result property="cardType"          column="card_type"          />
        <result property="status"            column="status"             />
        <result property="balance"           column="balance"            />
        <result property="currency"          column="currency"           />
        <result property="budgetAmount"      column="budget_amount"      />
        <result property="upstreamCardId"    column="upstream_card_id"   />
        <result property="expiryDate"        column="expiry_date"        />
        <result property="isAutoActivate"    column="is_auto_activate"   />
        <result property="activatedAt"       column="activated_at"       />
        <result property="cancelledAt"       column="cancelled_at"       />
        <result property="createTime"        column="created_at"         />
        <result property="updateTime"        column="updated_at"         />
    </resultMap>

    <sql id="selectCardVo">
        select id, holder_id, user_id, card_no_mask, card_bin_id, card_type, status,
               balance, currency, budget_amount, upstream_card_id, expiry_date,
               is_auto_activate, activated_at, cancelled_at, created_at, updated_at
        from vcc_card
    </sql>

    <select id="selectCardById" parameterType="Long" resultMap="CardResult">
        <include refid="selectCardVo"/>
        where id = #{id}
    </select>

    <select id="selectCardByUpstreamCardId" parameterType="String" resultMap="CardResult">
        <include refid="selectCardVo"/>
        where upstream_card_id = #{upstreamCardId}
    </select>

    <select id="selectCardList" parameterType="com.vcc.card.domain.Card" resultMap="CardResult">
        <include refid="selectCardVo"/>
        <where>
            <if test="holderId != null">AND holder_id = #{holderId}</if>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="cardNoMask != null and cardNoMask != ''">AND card_no_mask like concat('%', #{cardNoMask}, '%')</if>
            <if test="cardBinId != null and cardBinId != ''">AND card_bin_id = #{cardBinId}</if>
            <if test="cardType != null">AND card_type = #{cardType}</if>
            <if test="status != null">AND status = #{status}</if>
            <if test="currency != null and currency != ''">AND currency = #{currency}</if>
            <if test="upstreamCardId != null and upstreamCardId != ''">AND upstream_card_id = #{upstreamCardId}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertCard" parameterType="com.vcc.card.domain.Card" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_card (
            <if test="holderId != null">holder_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="cardNoMask != null and cardNoMask != ''">card_no_mask,</if>
            <if test="cardBinId != null and cardBinId != ''">card_bin_id,</if>
            <if test="cardType != null">card_type,</if>
            <if test="status != null">status,</if>
            <if test="balance != null">balance,</if>
            <if test="currency != null and currency != ''">currency,</if>
            <if test="budgetAmount != null">budget_amount,</if>
            <if test="upstreamCardId != null and upstreamCardId != ''">upstream_card_id,</if>
            <if test="expiryDate != null and expiryDate != ''">expiry_date,</if>
            <if test="isAutoActivate != null">is_auto_activate,</if>
            <if test="activatedAt != null">activated_at,</if>
            created_at
        ) values (
            <if test="holderId != null">#{holderId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="cardNoMask != null and cardNoMask != ''">#{cardNoMask},</if>
            <if test="cardBinId != null and cardBinId != ''">#{cardBinId},</if>
            <if test="cardType != null">#{cardType},</if>
            <if test="status != null">#{status},</if>
            <if test="balance != null">#{balance},</if>
            <if test="currency != null and currency != ''">#{currency},</if>
            <if test="budgetAmount != null">#{budgetAmount},</if>
            <if test="upstreamCardId != null and upstreamCardId != ''">#{upstreamCardId},</if>
            <if test="expiryDate != null and expiryDate != ''">#{expiryDate},</if>
            <if test="isAutoActivate != null">#{isAutoActivate},</if>
            <if test="activatedAt != null">#{activatedAt},</if>
            sysdate()
        )
    </insert>

    <update id="updateCard" parameterType="com.vcc.card.domain.Card">
        update vcc_card
        <set>
            <if test="cardNoMask != null and cardNoMask != ''">card_no_mask = #{cardNoMask},</if>
            <if test="cardType != null">card_type = #{cardType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="balance != null">balance = #{balance},</if>
            <if test="currency != null and currency != ''">currency = #{currency},</if>
            <if test="budgetAmount != null">budget_amount = #{budgetAmount},</if>
            <if test="upstreamCardId != null and upstreamCardId != ''">upstream_card_id = #{upstreamCardId},</if>
            <if test="expiryDate != null and expiryDate != ''">expiry_date = #{expiryDate},</if>
            <if test="isAutoActivate != null">is_auto_activate = #{isAutoActivate},</if>
            <if test="activatedAt != null">activated_at = #{activatedAt},</if>
            <if test="cancelledAt != null">cancelled_at = #{cancelledAt},</if>
            updated_at = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteCardById" parameterType="Long">
        delete from vcc_card where id = #{id}
    </delete>

    <delete id="deleteCardByIds" parameterType="Long">
        delete from vcc_card where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
