<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.card.mapper.Vcc3dsOtpLogMapper">

    <resultMap type="com.vcc.card.domain.Vcc3dsOtpLog" id="Vcc3dsOtpLogResult">
        <result property="id"                column="id"                 />
        <result property="userId"            column="user_id"            />
        <result property="cardId"            column="card_id"            />
        <result property="cardNoMask"        column="card_no_mask"       />
        <result property="holderId"          column="holder_id"          />
        <result property="otpCode"           column="otp_code"           />
        <result property="merchantName"      column="merchant_name"      />
        <result property="transactionAmount" column="transaction_amount" />
        <result property="currency"          column="currency"           />
        <result property="destinationEmail"  column="destination_email"  />
        <result property="status"            column="status"             />
        <result property="webhookPayload"    column="webhook_payload"    />
        <result property="createdAt"         column="created_at"         />
        <result property="verifiedAt"        column="verified_at"        />
    </resultMap>

    <sql id="selectVcc3dsOtpLogVo">
        select id, user_id, card_id, card_no_mask, holder_id, otp_code, merchant_name,
               transaction_amount, currency, destination_email, status, webhook_payload,
               created_at, verified_at
        from vcc_3ds_otp_log
    </sql>

    <select id="selectVcc3dsOtpLogById" parameterType="Long" resultMap="Vcc3dsOtpLogResult">
        <include refid="selectVcc3dsOtpLogVo"/>
        where id = #{id}
    </select>

    <select id="selectVcc3dsOtpLogList" parameterType="com.vcc.card.domain.Vcc3dsOtpLog" resultMap="Vcc3dsOtpLogResult">
        <include refid="selectVcc3dsOtpLogVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="cardId != null and cardId != ''">AND card_id = #{cardId}</if>
            <if test="cardNoMask != null and cardNoMask != ''">AND card_no_mask like concat('%', #{cardNoMask}, '%')</if>
            <if test="status != null">AND status = #{status}</if>
            <if test="params != null and params.beginTime != null and params.beginTime != ''">
                AND created_at &gt;= #{params.beginTime}
            </if>
            <if test="params != null and params.endTime != null and params.endTime != ''">
                AND created_at &lt;= #{params.endTime}
            </if>
        </where>
        order by id desc
    </select>

    <insert id="insertVcc3dsOtpLog" parameterType="com.vcc.card.domain.Vcc3dsOtpLog" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_3ds_otp_log (
            user_id,
            card_id,
            <if test="cardNoMask != null and cardNoMask != ''">card_no_mask,</if>
            <if test="holderId != null">holder_id,</if>
            <if test="otpCode != null and otpCode != ''">otp_code,</if>
            <if test="merchantName != null and merchantName != ''">merchant_name,</if>
            <if test="transactionAmount != null">transaction_amount,</if>
            <if test="currency != null and currency != ''">currency,</if>
            <if test="destinationEmail != null and destinationEmail != ''">destination_email,</if>
            status,
            <if test="webhookPayload != null">webhook_payload,</if>
            created_at
        ) values (
            #{userId},
            #{cardId},
            <if test="cardNoMask != null and cardNoMask != ''">#{cardNoMask},</if>
            <if test="holderId != null">#{holderId},</if>
            <if test="otpCode != null and otpCode != ''">#{otpCode},</if>
            <if test="merchantName != null and merchantName != ''">#{merchantName},</if>
            <if test="transactionAmount != null">#{transactionAmount},</if>
            <if test="currency != null and currency != ''">#{currency},</if>
            <if test="destinationEmail != null and destinationEmail != ''">#{destinationEmail},</if>
            #{status},
            <if test="webhookPayload != null">#{webhookPayload},</if>
            sysdate()
        )
    </insert>

</mapper>
