<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.export.mapper.ExportTaskMapper">

    <resultMap type="com.vcc.export.domain.ExportTask" id="ExportTaskResult">
        <result property="id"               column="id"                />
        <result property="merchantId"       column="merchant_id"       />
        <result property="exportType"       column="export_type"       />
        <result property="language"         column="language"          />
        <result property="fileName"         column="file_name"         />
        <result property="filePath"         column="file_path"         />
        <result property="fileFormat"       column="file_format"       />
        <result property="status"           column="status"            />
        <result property="filterParams"     column="filter_params"     />
        <result property="requesterId"      column="requester_id"      />
        <result property="submitTime"       column="submit_time"       />
        <result property="finishTime"       column="finish_time"       />
        <result property="errorMessage"     column="error_message"     />
        <result property="delFlag"          column="del_flag"          />
        <result property="createdAt"        column="created_at"        />
        <result property="updatedAt"        column="updated_at"        />
    </resultMap>

    <sql id="selectExportTaskVo">
        select id, merchant_id, export_type, language, file_name, file_path, file_format,
               status, filter_params, requester_id, submit_time, finish_time,
               error_message, del_flag, created_at, updated_at
        from vcc_export_task
        where del_flag = '0'
    </sql>

    <select id="selectExportTaskById" parameterType="Long" resultMap="ExportTaskResult">
        <include refid="selectExportTaskVo"/>
        and id = #{id}
    </select>

    <select id="selectExportTaskList" parameterType="com.vcc.export.domain.ExportTask" resultMap="ExportTaskResult">
        <include refid="selectExportTaskVo"/>
        <if test="merchantId != null">and merchant_id = #{merchantId}</if>
        <if test="exportType != null and exportType != ''">and export_type = #{exportType}</if>
        <if test="language != null and language != ''">and language = #{language}</if>
        <if test="fileName != null and fileName != ''">and file_name like concat('%', #{fileName}, '%')</if>
        <if test="fileFormat != null and fileFormat != ''">and file_format = #{fileFormat}</if>
        <if test="status != null and status != ''">and status = #{status}</if>
        <if test="requesterId != null">and requester_id = #{requesterId}</if>
        order by id desc
    </select>

    <select id="selectPendingTasks" resultMap="ExportTaskResult">
        <include refid="selectExportTaskVo"/>
        and status = 'PENDING'
        order by id desc
    </select>

    <insert id="insertExportTask" parameterType="com.vcc.export.domain.ExportTask" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_export_task (
            <if test="merchantId != null">merchant_id,</if>
            <if test="exportType != null and exportType != ''">export_type,</if>
            <if test="language != null and language != ''">language,</if>
            <if test="fileName != null and fileName != ''">file_name,</if>
            <if test="filePath != null and filePath != ''">file_path,</if>
            <if test="fileFormat != null and fileFormat != ''">file_format,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="filterParams != null and filterParams != ''">filter_params,</if>
            <if test="requesterId != null">requester_id,</if>
            <if test="errorMessage != null and errorMessage != ''">error_message,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            submit_time,
            created_at
        ) values (
            <if test="merchantId != null">#{merchantId},</if>
            <if test="exportType != null and exportType != ''">#{exportType},</if>
            <if test="language != null and language != ''">#{language},</if>
            <if test="fileName != null and fileName != ''">#{fileName},</if>
            <if test="filePath != null and filePath != ''">#{filePath},</if>
            <if test="fileFormat != null and fileFormat != ''">#{fileFormat},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="filterParams != null and filterParams != ''">#{filterParams},</if>
            <if test="requesterId != null">#{requesterId},</if>
            <if test="errorMessage != null and errorMessage != ''">#{errorMessage},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            sysdate(),
            sysdate()
        )
    </insert>

    <update id="updateExportTask" parameterType="com.vcc.export.domain.ExportTask">
        update vcc_export_task
        <set>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="exportType != null and exportType != ''">export_type = #{exportType},</if>
            <if test="language != null and language != ''">language = #{language},</if>
            <if test="fileName != null and fileName != ''">file_name = #{fileName},</if>
            <if test="filePath != null and filePath != ''">file_path = #{filePath},</if>
            <if test="fileFormat != null and fileFormat != ''">file_format = #{fileFormat},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="filterParams != null and filterParams != ''">filter_params = #{filterParams},</if>
            <if test="requesterId != null">requester_id = #{requesterId},</if>
            <if test="finishTime != null">finish_time = #{finishTime},</if>
            <if test="errorMessage != null and errorMessage != ''">error_message = #{errorMessage},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            updated_at = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteExportTaskById" parameterType="Long">
        update vcc_export_task set del_flag = '1' where id = #{id}
    </delete>

    <delete id="deleteExportTaskByIds" parameterType="Long">
        update vcc_export_task set del_flag = '1' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
