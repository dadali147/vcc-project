<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcc.risk.mapper.RiskRuleMapper">

    <resultMap type="com.vcc.risk.domain.RiskRule" id="RiskRuleResult">
        <result property="id"              column="id"               />
        <result property="ruleCode"        column="rule_code"        />
        <result property="ruleName"        column="rule_name"        />
        <result property="ruleType"        column="rule_type"        />
        <result property="scope"           column="scope"            />
        <result property="merchantId"      column="merchant_id"      />
        <result property="thresholdAmount" column="threshold_amount" />
        <result property="thresholdCount"  column="threshold_count"  />
        <result property="priority"        column="priority"         />
        <result property="cardType"        column="card_type"        />
        <result property="action"          column="action"           />
        <result property="status"          column="status"           />
        <result property="remark"          column="remark"           />
        <result property="delFlag"         column="del_flag"         />
        <result property="createdAt"       column="created_at"       />
        <result property="updatedAt"       column="updated_at"       />
    </resultMap>

    <sql id="selectRiskRuleVo">
        select id, rule_code, rule_name, rule_type, scope, merchant_id,
               threshold_amount, threshold_count, priority, card_type,
               action, status, remark, del_flag, created_at, updated_at
        from vcc_risk_rule
        where del_flag = '0'
    </sql>

    <select id="selectRiskRuleById" parameterType="Long" resultMap="RiskRuleResult">
        <include refid="selectRiskRuleVo"/>
        and id = #{id}
    </select>

    <select id="selectRiskRuleList" parameterType="com.vcc.risk.domain.RiskRule" resultMap="RiskRuleResult">
        <include refid="selectRiskRuleVo"/>
        <if test="ruleCode != null and ruleCode != ''">and rule_code = #{ruleCode}</if>
        <if test="ruleName != null and ruleName != ''">and rule_name like concat('%', #{ruleName}, '%')</if>
        <if test="ruleType != null and ruleType != ''">and rule_type = #{ruleType}</if>
        <if test="scope != null and scope != ''">and scope = #{scope}</if>
        <if test="merchantId != null">and merchant_id = #{merchantId}</if>
        <if test="cardType != null and cardType != ''">and card_type = #{cardType}</if>
        <if test="action != null and action != ''">and action = #{action}</if>
        <if test="status != null and status != ''">and status = #{status}</if>
        order by COALESCE(priority, 999) asc, id desc
    </select>

    <select id="selectEnabledRulesByType" resultMap="RiskRuleResult">
        <include refid="selectRiskRuleVo"/>
        and status = 'ENABLED'
        and rule_type = #{ruleType}
        and (
            scope = 'GLOBAL'
            or (scope = 'MERCHANT' and merchant_id = #{merchantId})
        )
        order by COALESCE(priority, 999) asc,
                 case when scope = 'MERCHANT' and merchant_id = #{merchantId} then 0 else 1 end,
                 threshold_amount asc,
                 id asc
    </select>

    <select id="selectRiskRuleByCode" resultMap="RiskRuleResult">
        <include refid="selectRiskRuleVo"/>
        and rule_code = #{ruleCode}
        limit 1
    </select>

    <!-- 统计商户当日风控事件次数（基于已触发的风控事件记录） -->
    <select id="countDailyTransactions" resultType="int">
        select count(*)
        from vcc_risk_event
        where del_flag = '0'
          and merchant_id = #{merchantId}
          and DATE(created_at) = CURDATE()
    </select>

    <!-- 统计商户当日风控事件累计金额（基于已触发的风控事件记录） -->
    <!-- 注意：此处统计的是风控事件表，非充值表。充值日累计风控口径见 RechargeMapper.selectTodayRechargeTotal -->
    <select id="sumDailyAmount" resultType="java.math.BigDecimal">
        select COALESCE(SUM(
            CAST(JSON_EXTRACT(trigger_detail, '$.amount') AS DECIMAL(20,2))
        ), 0)
        from vcc_risk_event
        where del_flag = '0'
          and merchant_id = #{merchantId}
          and DATE(created_at) = CURDATE()
    </select>

    <insert id="insertRiskRule" parameterType="com.vcc.risk.domain.RiskRule" useGeneratedKeys="true" keyProperty="id">
        insert into vcc_risk_rule (
            <if test="ruleCode != null and ruleCode != ''">rule_code,</if>
            <if test="ruleName != null and ruleName != ''">rule_name,</if>
            <if test="ruleType != null and ruleType != ''">rule_type,</if>
            <if test="scope != null and scope != ''">scope,</if>
            <if test="merchantId != null">merchant_id,</if>
            <if test="thresholdAmount != null">threshold_amount,</if>
            <if test="thresholdCount != null">threshold_count,</if>
            <if test="priority != null">priority,</if>
            <if test="cardType != null and cardType != ''">card_type,</if>
            <if test="action != null and action != ''">action,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            created_at
        ) values (
            <if test="ruleCode != null and ruleCode != ''">#{ruleCode},</if>
            <if test="ruleName != null and ruleName != ''">#{ruleName},</if>
            <if test="ruleType != null and ruleType != ''">#{ruleType},</if>
            <if test="scope != null and scope != ''">#{scope},</if>
            <if test="merchantId != null">#{merchantId},</if>
            <if test="thresholdAmount != null">#{thresholdAmount},</if>
            <if test="thresholdCount != null">#{thresholdCount},</if>
            <if test="priority != null">#{priority},</if>
            <if test="cardType != null and cardType != ''">#{cardType},</if>
            <if test="action != null and action != ''">#{action},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateRiskRule" parameterType="com.vcc.risk.domain.RiskRule">
        update vcc_risk_rule
        <set>
            <if test="ruleCode != null and ruleCode != ''">rule_code = #{ruleCode},</if>
            <if test="ruleName != null and ruleName != ''">rule_name = #{ruleName},</if>
            <if test="ruleType != null and ruleType != ''">rule_type = #{ruleType},</if>
            <if test="scope != null and scope != ''">scope = #{scope},</if>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="thresholdAmount != null">threshold_amount = #{thresholdAmount},</if>
            <if test="thresholdCount != null">threshold_count = #{thresholdCount},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="cardType != null and cardType != ''">card_type = #{cardType},</if>
            <if test="action != null and action != ''">action = #{action},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            updated_at = sysdate()
        </set>
        where id = #{id} and del_flag = '0'
    </update>

    <update id="deleteRiskRuleById" parameterType="Long">
        update vcc_risk_rule set del_flag = '1', updated_at = sysdate() where id = #{id}
    </update>

    <update id="deleteRiskRuleByIds" parameterType="Long">
        update vcc_risk_rule set del_flag = '1', updated_at = sysdate() where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
